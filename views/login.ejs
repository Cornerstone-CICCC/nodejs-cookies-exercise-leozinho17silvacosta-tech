<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Login</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <div class="login-container">
        <h1>Login</h1>
        
        <% if (error) { %>
            <p style="color: red;"><%= error %></p>
        <% } %>

        <form action="/login" method="POST">
            <input type="text" name="username" placeholder="user (admin)" required>
            <input type="password" name="password" placeholder="password (admin12345)" required>
            <button type="submit">Sign in</button>
        </form>
    </div>
</body>
</html>